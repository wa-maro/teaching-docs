generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN @map("admin")
  USER  @map("user")
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String
  fullname     String?
  email        String?   @unique
  role         UserRole  @default(USER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]

  @@map("users")
}

model Session {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  userAgent  String
  ipAddress  String
  lastUsedAt DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("sessions")
}

enum LevelChoice {
  ORDINARY @map("ordinary")
  ADVANCED @map("advanced")
}

model Level {
  id        String      @id @default(uuid())
  name      LevelChoice @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  forms     Form[]

  @@map("levels")
}

enum FormChoice {
  ONE   @map("one")
  TWO   @map("two")
  THREE @map("three")
  FOUR  @map("four")
  FIVE  @map("five")
  SIX   @map("six")
}

model Form {
  id        String     @id @default(uuid())
  levelId   String
  name      FormChoice
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  level     Level      @relation(fields: [levelId], references: [id])

  @@unique([levelId, name])
  @@map("forms")
}

enum LanguageChoice {
  SW
  EN
  FR
  ZH
  AR
}

model Subject {
  id                     String         @id @default(uuid())
  name                   String         @unique
  instructional_language LanguageChoice @default(EN)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@map("subjects")
}

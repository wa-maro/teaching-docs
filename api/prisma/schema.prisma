generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN @map("admin")
  USER  @map("user")
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String
  fullname     String?
  email        String?   @unique
  role         UserRole  @default(USER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]

  @@map("users")
}

model Session {
  id         String    @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  userAgent  String
  ipAddress  String
  lastUsedAt DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("sessions")
}

enum LevelChoice {
  ORDINARY @map("ordinary")
  ADVANCED @map("advanced")
}

model Level {
  id            String         @id @default(uuid())
  name          LevelChoice    @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  forms         Form[]
  levelSubjects LevelSubject[]

  @@map("levels")
}

enum FormChoice {
  ONE   @map("one")
  TWO   @map("two")
  THREE @map("three")
  FOUR  @map("four")
  FIVE  @map("five")
  SIX   @map("six")
}

model Form {
  id           String        @id @default(uuid())
  levelId      String
  name         FormChoice
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  level        Level         @relation(fields: [levelId], references: [id])
  formSubjects FormSubject[]

  @@unique([levelId, name])
  @@map("forms")
}

enum LanguageChoice {
  SW
  EN
  FR
  ZH
  AR
}

model Subject {
  id                     String         @id @default(uuid())
  name                   String         @unique
  instructional_language LanguageChoice @default(EN)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  levelSubjects          LevelSubject[]

  @@map("subjects")
}

model LevelSubject {
  id           String        @id @default(uuid())
  levelId      String
  subjectId    String
  code         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  level        Level         @relation(fields: [levelId], references: [id])
  subject      Subject       @relation(fields: [subjectId], references: [id])
  formSubjects FormSubject[]
  syllabi      Syllabus[]

  @@unique([levelId, subjectId])
  @@map("level_subjects")
}

enum SubjectTypeChoice {
  COMPULSORY @map("compulsory")
  OPTIONAL   @map("optional")
}

model FormSubject {
  id             String            @id @default(uuid())
  formId         String
  levelSubjectId String
  subjectType    SubjectTypeChoice @default(COMPULSORY)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  form           Form              @relation(fields: [formId], references: [id])
  levelSubject   LevelSubject      @relation(fields: [levelSubjectId], references: [id])

  @@unique([formId, levelSubjectId])
  @@map("form_subjects")
}

model Syllabus {
  id              String           @id @default(uuid())
  levelSubjectId  String
  publishedYear   Int
  revisedYear     Int?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  levelSubject    LevelSubject     @relation(fields: [levelSubjectId], references: [id])
  mainCompetences MainCompetence[]

  @@unique([levelSubjectId, publishedYear])
  @@map("syllabi")
}

model MainCompetence {
  id         String   @id @default(uuid())
  syllabusId String
  position   Int
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  syllabus   Syllabus @relation(fields: [syllabusId], references: [id])

  @@unique([syllabusId, position])
  @@map("main_competences")
}
